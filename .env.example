# ── BillKaro environment configuration ────────────────────────────
# Copy this file to .env and fill in the values.

# PostgreSQL connection string.
# For Docker Compose this is set automatically in docker-compose.yml;
# you only need POSTGRES_PASSWORD below.
DATABASE_URL="postgresql://billkaro:CHANGE_ME@localhost:5432/billkaro"

# Secret used to sign login session cookies.
# Use a long random value (32+ characters). Example generator:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Password for the bundled PostgreSQL container (Docker Compose only).
POSTGRES_PASSWORD="CHANGE_ME"

# Optional: seed demo data (Babar General Store) on first start. 1 = yes.
RUN_SEED="0"
